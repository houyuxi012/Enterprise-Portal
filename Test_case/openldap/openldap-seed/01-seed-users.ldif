# ============================================================
# 组织结构: 百度 > 财务部 / 设计部 / 研发中心
#   设计部 > 设计一组 / 设计二组
#   研发中心 > 北京研发中心 / 上海研发中心
#     北京研发中心 > 研发一组 / 研发二组
#       研发二组 > 外包组
# Base DN: dc=baiduinc,dc=com
# ============================================================

# --- 顶层 OU ---
dn: ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 百度

# --- 一级部门 OU ---
dn: ou=财务部,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 财务部

dn: ou=设计部,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 设计部

dn: ou=研发中心,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 研发中心

# --- 设计部子组 ---
dn: ou=设计一组,ou=设计部,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 设计一组

dn: ou=设计二组,ou=设计部,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 设计二组

# --- 研发中心子组 ---
dn: ou=北京研发中心,ou=研发中心,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 北京研发中心

dn: ou=上海研发中心,ou=研发中心,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 上海研发中心

# --- 北京研发中心子组 ---
dn: ou=研发一组,ou=北京研发中心,ou=研发中心,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 研发一组

dn: ou=研发二组,ou=北京研发中心,ou=研发中心,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 研发二组

# --- 研发二组子组 ---
dn: ou=外包组,ou=研发二组,ou=北京研发中心,ou=研发中心,ou=百度,dc=baiduinc,dc=com
objectClass: organizationalUnit
ou: 外包组

